# Copie para `.env.local` e preencha com os dados do Console do Firebase.
# https://console.firebase.google.com/ → projeto → Configurações → Seus apps → Web (</>)
#
# Passos:
# 1. Firebase → Visão geral → Adicionar app → ícone Web (</>)
# 2. Copie cada campo da "Configuração do SDK" para baixo (sem aspas)
# 3. Vercel → Settings → Environment Variables → mesmas chaves → Redeploy
# 4. Firebase → Authentication → Sign-in method → ativar E-mail/senha
# 5. Firebase → Authentication → Settings → Authorized domains → domínio Vercel

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
